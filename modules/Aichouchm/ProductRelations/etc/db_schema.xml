<?xml version="1.0"?>
<!--
    Declarative Schema — preferred over InstallSchema scripts.
    Magento computes the diff and applies only what changed.
-->
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="aichouchm_product_relation" resource="default" engine="innodb"
           comment="Aichouchm Product Relations">

        <column xsi:type="int"       name="entity_id"          unsigned="true"  nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int"       name="product_id"         unsigned="true"  nullable="false"                 comment="Source Product ID"/>
        <column xsi:type="int"       name="related_product_id" unsigned="true"  nullable="false"                 comment="Related Product ID"/>
        <column xsi:type="varchar"   name="relation_type"      nullable="false" length="64"                      comment="Relation Type (color/size/sibling/accessory)"/>
        <column xsi:type="smallint"  name="sort_order"         unsigned="true"  nullable="false" default="0"     comment="Sort Order"/>
        <column xsi:type="boolean"   name="is_active"          nullable="false" default="true"                   comment="Is Active"/>
        <column xsi:type="timestamp" name="created_at"         nullable="false" default="CURRENT_TIMESTAMP"      comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at"         nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>

        <!-- Prevent duplicate entries for the same product pair + type -->
        <constraint xsi:type="unique" referenceId="AICHOUCHM_PRODUCT_RELATION_UNIQUE">
            <column name="product_id"/>
            <column name="related_product_id"/>
            <column name="relation_type"/>
        </constraint>

        <!-- FK to catalog_product_entity (cascade on delete) -->
        <constraint xsi:type="foreign"
                    referenceId="AICHOUCHM_PRODUCT_RELATION_PRODUCT_ID"
                    table="aichouchm_product_relation"
                    column="product_id"
                    referenceTable="catalog_product_entity"
                    referenceColumn="entity_id"
                    onDelete="CASCADE"/>

        <constraint xsi:type="foreign"
                    referenceId="AICHOUCHM_PRODUCT_RELATION_RELATED_ID"
                    table="aichouchm_product_relation"
                    column="related_product_id"
                    referenceTable="catalog_product_entity"
                    referenceColumn="entity_id"
                    onDelete="CASCADE"/>

        <!-- Index for fast reverse lookups -->
        <index referenceId="AICHOUCHM_PRODUCT_RELATION_PRODUCT_TYPE_ACTIVE" indexType="btree">
            <column name="product_id"/>
            <column name="relation_type"/>
            <column name="is_active"/>
            <column name="sort_order"/>
        </index>

    </table>

</schema>
