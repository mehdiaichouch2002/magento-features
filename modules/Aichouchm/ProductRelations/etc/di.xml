<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Service contract wiring -->
    <preference for="Aichouchm\ProductRelations\Api\ProductRelationRepositoryInterface"
                type="Aichouchm\ProductRelations\Model\ProductRelationRepository"/>

    <preference for="Aichouchm\ProductRelations\Api\Data\ProductRelationInterface"
                type="Aichouchm\ProductRelations\Model\ProductRelation"/>

    <preference for="Aichouchm\ProductRelations\Api\Data\ProductRelationSearchResultsInterface"
                type="Magento\Framework\Api\SearchResults"/>

    <!-- Virtual type: cached repository (wraps the real one with a cache layer) -->
    <virtualType name="Aichouchm\ProductRelations\Model\Cache\ProductRelationCache"
                 type="Magento\Framework\Cache\Frontend\Decorator\TagScope">
        <arguments>
            <argument name="frontend" xsi:type="object">Magento\Framework\App\Cache\Type\Config</argument>
            <argument name="tag" xsi:type="string">PRODUCT_RELATION</argument>
        </arguments>
    </virtualType>

</config>
