# ─── Magento Marketplace credentials ─────────────────────────────────────────
# Free account required: https://commercemarketplace.adobe.com/customer/accessKeys/
MAGENTO_REPO_PUBLIC_KEY=
MAGENTO_REPO_PRIVATE_KEY=

# ─── Magento ──────────────────────────────────────────────────────────────────
MAGENTO_VERSION=2.4.7
MAGENTO_MODE=developer
MAGENTO_BASE_URL=http://magento.local/
MAGENTO_ADMIN_URI=admin
MAGENTO_ADMIN_FIRSTNAME=Admin
MAGENTO_ADMIN_LASTNAME=User
MAGENTO_ADMIN_EMAIL=admin@magento.local
MAGENTO_ADMIN_USER=admin
MAGENTO_ADMIN_PASSWORD=Admin123!

# ─── PHP ──────────────────────────────────────────────────────────────────────
PHP_MEMORY_LIMIT=2G
PHP_MEMORY_LIMIT_CLI=4G
XDEBUG_ENABLED=false

# ─── Nginx ────────────────────────────────────────────────────────────────────
# Port 8080: direct PHP access (bypass Varnish)
# Port  80 : via Varnish (FPC enabled)
NGINX_DIRECT_PORT=8080

# ─── Varnish ──────────────────────────────────────────────────────────────────
VARNISH_PORT=80
VARNISH_SIZE=256m

# ─── MySQL / MariaDB ──────────────────────────────────────────────────────────
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=magento
MYSQL_DATABASE=magento
MYSQL_USER=magento
MYSQL_PASSWORD=magento

# ─── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_PORT=9200

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=magento
RABBITMQ_PASSWORD=magento
RABBITMQ_VHOST=magento

# ─── Mailhog ──────────────────────────────────────────────────────────────────
MAILHOG_HTTP_PORT=8025
