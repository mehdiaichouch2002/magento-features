volumes/.composer/
volumes/.ssh/

# ─── OpenSearch data ─────────────────────────────────────────────────────────
elasticsearch/

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

